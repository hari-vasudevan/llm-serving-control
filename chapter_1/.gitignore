# MATLAB gitignore

# Compiled MEX binaries
*.mex*
*.mexw32
*.mexw64
*.mexmaci64
*.mexmaca64

# Simulink generated code and build artifacts
slprj/
sccprj/
codegen/
*.slxc
*.slxp

# Simulink cache and autosave
*.autosave
*.bak

# MATLAB figure files (regenerated by scripts)
*.fig

# MATLAB binary data files (usually regenerated)
*.mat
*.mltbx
*.mlapp
*.mlx~

# Project derived files
work/
*.lock

# MATLAB profiling
*.mlprofilerReport

# Crash dumps
*.mdmp

# Build output
build/
bin/

# Simulation output images (regenerated by run_simulation.m)
results_*.png

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor backup files
*~
\#*\#
.#*
