# LLM Inference Control — Project .gitignore

# MATLAB build artefacts
*.slxc
slprj/
*.asv
*.mex*
*.mexa64

# Run artefacts — timestamped output files from experiments
# Keep: final identified_params.mat, controller_params.mat, b_sweep plots
# Drop: timestamped run logs and intermediate plots
**/run_log.mat
**/ch*_run_log_*.json
**/ch*_cascade_log_*.json
**/ch*_run_log_*.mat

# Timestamped intermediate plots (pattern: name_HHMMSS.png)
**/ch*_cascade_1[0-9][0-9][0-9][0-9][0-9].png
**/ch*_cascade_2[0-9][0-9][0-9][0-9][0-9].png
**/ch*_closed_loop_1[0-9][0-9][0-9][0-9][0-9].png
**/ch*_single_loop_1[0-9][0-9][0-9][0-9][0-9].png
**/ch*_single_ttft_1[0-9][0-9][0-9][0-9][0-9].png
**/ch*_recovered.png

# Python artefacts
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Logs
*.log
/tmp/

# macOS
.DS_Store

# Large binary / vllm build directories
vllm-*/
*.whl
